@startuml c4-deployment
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.13.0/C4_Deployment.puml
!include _skinparam.iuml

title Deployment — Kubernetes (Pizza Store Platform)

Person(customer, "Customer")

Deployment_Node(k8s, "Kubernetes cluster", "v1.34+") {
  Deployment_Node(ns, "Namespace: default") {
    Container(lb, "Service: pizza-store", "LoadBalancer 80 -> 8080 (cloud-provider-kind / cloud LB)")

    Deployment_Node(appPod, "Pod (x 3: pizza-store, pizza-kitchen, pizza-delivery)") {
      Container(app, "Spring Boot service", "Spring Boot 4.0.5, Java 21 — three per-service replicas")
      Container(sidecar, "Dapr sidecar", "Dapr 1.17.2 — injected per pod; app-ids match service names")
    }

    ContainerQueue(pubsub, "PubSub backend", "Kafka (prod) / Redis (e2e)")
    ContainerDb(state, "State Store backend", "PostgreSQL (prod) / Redis (e2e)")
  }

  Deployment_Node(daprSys, "Namespace: dapr-system") {
    Container(daprCtrl, "Dapr control plane", "Helm chart dapr 1.17.4 — operator, placement, sentry, injector")
  }
}

Rel(customer, lb, "HTTPS / WebSocket")
Rel(lb, app, "Routes to pizza-store:8080")

Rel(sidecar, sidecar, "Service invocation between sidecars", "mTLS HTTP/gRPC")
Rel(sidecar, state, "Persist orders (pizza-store)")
Rel(sidecar, pubsub, "Publish / subscribe events")
Rel(sidecar, daprCtrl, "Placement lookup, cert rotation", "gRPC")

SHOW_LEGEND()
@enduml
