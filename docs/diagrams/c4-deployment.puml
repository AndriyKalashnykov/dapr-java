@startuml c4-deployment
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.13.0/C4_Deployment.puml
!include _skinparam.iuml

title Deployment — Kubernetes (Pizza Store Platform)

Person(customer, "Customer")

Deployment_Node(k8s, "Kubernetes cluster", "v1.35+") {
  Deployment_Node(ns, "Namespace: default") {
    Container(lb, "Service: pizza-store", "LoadBalancer 80 -> 8080 (cloud-provider-kind / cloud LB)")

    ' Per-pod app + Dapr sidecar collapsed into one Container — the sidecar
    ' is co-deployed in the same Pod (shared loopback) and the app-id is
    ' a Dapr identity, not a separate runtime. Keeps the deployment view
    ' focused on Pods and their Dapr app-id, not on every container in
    ' each Pod.
    Container(storePod, "Pod: pizza-store + Dapr sidecar", "Spring Boot 4.0.6, Java 21 (app-id: pizza-store)")
    Container(kitchenPod, "Pod: pizza-kitchen + Dapr sidecar", "Spring Boot 4.0.6, Java 21 (app-id: kitchen-service)")
    Container(deliveryPod, "Pod: pizza-delivery + Dapr sidecar", "Spring Boot 4.0.6, Java 21 (app-id: delivery-service)")

    ContainerQueue(pubsub, "PubSub backend", "Kafka (managed) / Redis (e2e)")
    ContainerDb(state, "State Store backend", "PostgreSQL (managed) / Redis (e2e)")
  }

  Deployment_Node(daprSys, "Namespace: dapr-system") {
    Container(daprCtrl, "Dapr control plane", "Helm chart dapr 1.17.7 — operator, placement, sentry, injector")
  }
}

Rel(customer, lb, "HTTPS / WebSocket")
Rel(lb, storePod, "Routes to pizza-store:8080")

' Cross-pod service invocation flows through each pod's local Dapr
' sidecar over mTLS — drawn pod-to-pod here to keep the count under the
' Container-diagram budget.
Rel(storePod, kitchenPod, "Invoke kitchen-service", "Dapr / mTLS HTTP/gRPC")
Rel(storePod, deliveryPod, "Invoke delivery-service", "Dapr / mTLS HTTP/gRPC")

Rel(storePod, state, "Persist orders", "Dapr state API")
Rel(kitchenPod, pubsub, "Publish ORDER_IN_PREPARATION, ORDER_READY", "CloudEvents")
Rel(deliveryPod, pubsub, "Publish ORDER_ON_ITS_WAY, ORDER_COMPLETED", "CloudEvents")
Rel(pubsub, storePod, "Deliver subscribed events", "CloudEvents -> POST /events")

Rel(storePod, daprCtrl, "Placement lookup, cert rotation", "gRPC (sidecar)")

SHOW_LEGEND()
@enduml
