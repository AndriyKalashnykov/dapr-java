@startuml c4-deployment
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.13.0/C4_Deployment.puml
!include _skinparam.iuml

title Deployment — Kubernetes (Pizza Store Platform)

Person(customer, "Customer")

Deployment_Node(k8s, "Kubernetes cluster", "v1.34+") {
  Deployment_Node(ns, "Namespace: default") {
    Container(lb, "Service: pizza-store", "LoadBalancer 80 -> 8080 (cloud-provider-kind / cloud LB)")

    Deployment_Node(storePod, "Pod: pizza-store") {
      Container(storeApp, "pizza-store", "Spring Boot 4.0.6, Java 21")
      Container(storeSidecar, "Dapr sidecar", "app-id: pizza-store")
    }
    Deployment_Node(kitchenPod, "Pod: pizza-kitchen") {
      Container(kitchenApp, "pizza-kitchen", "Spring Boot 4.0.6, Java 21")
      Container(kitchenSidecar, "Dapr sidecar", "app-id: kitchen-service")
    }
    Deployment_Node(deliveryPod, "Pod: pizza-delivery") {
      Container(deliveryApp, "pizza-delivery", "Spring Boot 4.0.6, Java 21")
      Container(deliverySidecar, "Dapr sidecar", "app-id: delivery-service")
    }

    ContainerQueue(pubsub, "PubSub backend", "Kafka (managed) / Redis (e2e)")
    ContainerDb(state, "State Store backend", "PostgreSQL (managed) / Redis (e2e)")
  }

  Deployment_Node(daprSys, "Namespace: dapr-system") {
    Container(daprCtrl, "Dapr control plane", "Helm chart dapr 1.17.5 — operator, placement, sentry, injector")
  }
}

Rel(customer, lb, "HTTPS / WebSocket")
Rel(lb, storeApp, "Routes to pizza-store:8080")

' Cross-pod service invocation flows store -> kitchen / delivery via the
' caller's local sidecar. The two arrows model the actual sidecar-to-sidecar
' hops; the apps invoke through localhost on their own sidecar (intra-pod).
Rel(storeSidecar, kitchenSidecar, "Invoke kitchen-service", "mTLS HTTP/gRPC")
Rel(storeSidecar, deliverySidecar, "Invoke delivery-service", "mTLS HTTP/gRPC")

Rel(storeSidecar, state, "Persist orders", "Dapr state API")
Rel(kitchenSidecar, pubsub, "Publish ORDER_IN_PREPARATION, ORDER_READY", "CloudEvents")
Rel(deliverySidecar, pubsub, "Publish ORDER_ON_ITS_WAY, ORDER_COMPLETED", "CloudEvents")
Rel(pubsub, storeSidecar, "Deliver subscribed events", "CloudEvents -> POST /events")

Rel(storeSidecar, daprCtrl, "Placement lookup, cert rotation", "gRPC")

SHOW_LEGEND()
@enduml
