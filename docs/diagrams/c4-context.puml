@startuml c4-context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.13.0/C4_Context.puml
!include _skinparam.iuml

title System Context — Cloud-Native Pizza Store

Person(customer, "Customer", "Places and tracks pizza orders via the web UI")

System(pizza, "Pizza Store Platform", "Orders, cooks, and delivers pizzas; three Spring Boot 4 services collaborating over Dapr building blocks")

System_Ext(dapr, "Dapr Runtime", "Sidecar building blocks — service invocation, pub/sub, state store")

Rel(customer, pizza, "Places and tracks orders", "HTTPS / WebSocket")
Rel(pizza, dapr, "Uses building blocks", "HTTP / gRPC on localhost")

SHOW_LEGEND()
@enduml
