@startuml c4-container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.13.0/C4_Container.puml
!include _skinparam.iuml

title Container View — Cloud-Native Pizza Store

Person(customer, "Customer", "Places and tracks pizza orders")

System_Boundary(pizza, "Pizza Store Platform") {
  Container(store, "pizza-store", "Spring Boot 4.0.5, Java 21", "Frontend + backend — places orders, receives event updates, pushes live status to the browser")
  Container(kitchen, "pizza-kitchen", "Spring Boot 4.0.5, Java 21", "Prepares pizzas; publishes ORDER_IN_PREPARATION and ORDER_READY")
  Container(delivery, "pizza-delivery", "Spring Boot 4.0.5, Java 21", "Delivers pizzas in three stages; publishes ORDER_ON_ITS_WAY (x3) and ORDER_COMPLETED")
  Container(daprSidecar, "Dapr sidecar", "Dapr 1.17.2", "One per pod (app-ids: pizza-store, kitchen-service, delivery-service) — brokers service invocation, pub/sub, state")
  ContainerDb(state, "State Store", "Dapr component kvstore", "PostgreSQL in prod / Redis in e2e — persists orders")
  ContainerQueue(pubsub, "PubSub", "Dapr component pubsub (topic: topic)", "Kafka in prod / Redis in e2e — CloudEvents transport")
}

Rel(customer, store, "Places order", "HTTPS / JSON")
Rel(store, customer, "Pushes live order status", "WebSocket /topic/events")

Rel(store, daprSidecar, "PUT /prepare, PUT /deliver, state RPCs", "HTTP / gRPC")
Rel(daprSidecar, kitchen, "Invokes kitchen-service (PUT /prepare)", "HTTP")
Rel(daprSidecar, delivery, "Invokes delivery-service (PUT /deliver)", "HTTP")

Rel(kitchen, pubsub, "Publishes ORDER_IN_PREPARATION, ORDER_READY", "CloudEvents")
Rel(delivery, pubsub, "Publishes ORDER_ON_ITS_WAY, ORDER_COMPLETED", "CloudEvents")
Rel(pubsub, store, "Delivers subscribed events", "POST /events (CloudEvent)")

Rel(daprSidecar, state, "Upsert / load orders", "Dapr state API")

SHOW_LEGEND()
@enduml
