@startuml c4-container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.13.0/C4_Container.puml
!include _skinparam.iuml

title Container View — Pizza on Dapr

Person(customer, "Customer", "Places and tracks pizza orders")

System_Boundary(pizza, "Pizza Store Platform") {
  Container(store, "pizza-store", "Spring Boot 4.0.6, Java 21", "Frontend + backend — places orders, receives event updates, pushes live status to the browser")
  Container(kitchen, "pizza-kitchen", "Spring Boot 4.0.6, Java 21", "Prepares pizzas; publishes ORDER_IN_PREPARATION and ORDER_READY")
  Container(delivery, "pizza-delivery", "Spring Boot 4.0.6, Java 21", "Delivers pizzas in three stages; publishes ORDER_ON_ITS_WAY (x3) and ORDER_COMPLETED")
  Container(daprSidecar, "Dapr sidecar", "Dapr runtime 1.17.7 (Helm) / 1.17.2 (Testcontainers)", "One per pod (app-ids: pizza-store, kitchen-service, delivery-service) — brokers service invocation, pub/sub, state")
  ' pubsub + state collapsed into one Dapr Components entity. The pub/sub
  ' (queue) vs state (db) semantic is preserved by the qualifier text in
  ' each Rel label below ("PubSub: …" / "State: …"). Keeps the Container
  ' view at <= 15 elements per the C4 soft cap; per-backend deployment
  ' detail (Kafka vs Redis, PostgreSQL vs Redis) lives in c4-deployment.
  ContainerDb(daprComponents, "Dapr Components", "kvstore (state) + pubsub (topic)", "PubSub (CloudEvents) + State Store — Kafka/PostgreSQL (managed) / Redis (e2e)")
}

' Customer↔Store is bidirectional: HTTPS/JSON in, STOMP WebSocket
' broadcast out. Collapsed into one BiRel to keep the diagram at the
' C4-PlantUML soft cap of 15 elements (was 16 with two separate Rels).
BiRel(customer, store, "HTTPS / JSON in, WebSocket /topic/events out")

Rel(store, daprSidecar, "PUT /prepare, PUT /deliver, state RPCs", "HTTP / gRPC")
Rel(daprSidecar, kitchen, "Invokes kitchen-service (PUT /prepare)", "HTTP")
Rel(daprSidecar, delivery, "Invokes delivery-service (PUT /deliver)", "HTTP")

Rel(kitchen, daprComponents, "Publishes ORDER_IN_PREPARATION, ORDER_READY", "PubSub: CloudEvents")
Rel(delivery, daprComponents, "Publishes ORDER_ON_ITS_WAY, ORDER_COMPLETED", "PubSub: CloudEvents")
Rel(daprComponents, store, "Delivers subscribed events", "PubSub: POST /events")

Rel(daprSidecar, daprComponents, "Upsert / load orders", "State: Dapr state API")

SHOW_LEGEND()
@enduml
